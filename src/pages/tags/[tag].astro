---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const uniqueTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))].sort((a, b) =>
		a.localeCompare(b)
	);

	return uniqueTags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((post) => (post.data.tags ?? []).includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props;

const navLinks = [
	{ href: '/', label: 'Home', isActive: false },
	{ href: '/blog', label: 'Posts', isActive: false },
	{ href: '/#about', label: 'About', isActive: false },
];

const formatDate = (date: Date) =>
	date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
---

<html lang="en" data-theme="editorial">
	<head>
		<meta charset="utf-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Tag: {tag} | Dev Blog</title>
	</head>
	<body class="editorial-shell min-h-screen bg-base-100 text-base-content">
		<header class="editorial-header sticky top-0 z-10 bg-base-100/90 backdrop-blur-sm">
			<div class="navbar mx-auto max-w-6xl px-4 sm:px-6">
				<div class="navbar-start">
					<a href="/" class="btn btn-ghost text-lg font-semibold tracking-tight text-base-content">Dev Blog</a>
				</div>
				<div class="navbar-center hidden lg:flex">
					<ul class="menu menu-horizontal gap-2 px-1">
						{navLinks.map((link) => (
							<li>
								<a href={link.href} class="nav-link" aria-current={link.isActive ? 'page' : undefined}>{link.label}</a>
							</li>
						))}
					</ul>
				</div>
				<div class="navbar-end">
					<a href="/blog" class="btn btn-outline btn-sm hidden sm:inline-flex">All posts</a>
					<div class="dropdown dropdown-end lg:hidden">
						<button class="btn btn-ghost" aria-label="Open navigation menu">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
						<ul class="menu dropdown-content z-10 mt-3 w-52 rounded-box border border-base-300 bg-base-200 p-2 shadow-lg">
							{navLinks.map((link) => (
								<li>
									<a href={link.href} class="nav-link" aria-current={link.isActive ? 'page' : undefined}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</header>

		<main class="relative z-10 mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-12">
			<section class="motion-reveal editorial-panel rounded-box px-6 py-7 sm:px-8 sm:py-8" style="--reveal-order: 0;">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="space-y-3">
						<a href="/blog" class="eyebrow text-xs font-medium editorial-link no-underline">Back to posts</a>
						<h1 class="font-display text-4xl font-semibold tracking-tight sm:text-5xl">Tag: {tag}</h1>
						<p class="max-w-2xl text-[1.02rem] leading-8 text-base-content/76">
							{posts.length} {posts.length === 1 ? 'post' : 'posts'} filed under this topic.
						</p>
					</div>
					<div class="badge badge-primary badge-outline px-4 py-4 text-xs font-medium uppercase tracking-[0.18em]">
						Topic archive
					</div>
				</div>
			</section>

			<section class="mt-8 grid gap-4 sm:mt-10">
				{posts.map((post, index) => (
					<article class="editorial-card motion-reveal card rounded-box border border-base-content/10 bg-base-200/80 shadow-xl" style={`--reveal-order: ${index + 1};`}>
						<div class="card-body gap-4">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<time datetime={post.data.pubDate.toISOString()} class="text-muted text-sm">
									{formatDate(post.data.pubDate)}
								</time>
								<div class="flex flex-wrap gap-2">
									{(post.data.tags ?? []).map((postTag) => (
										<a
											href={`/tags/${encodeURIComponent(postTag)}`}
											class:list={[
												'tag-badge',
												postTag === tag && 'is-active',
											]}
										>
											{postTag}
										</a>
									))}
								</div>
							</div>
							<div class="space-y-3">
								<h2 class="card-title text-2xl font-semibold leading-snug">{post.data.title}</h2>
								<p class="text-sm leading-7 text-base-content/72">{post.data.description}</p>
							</div>
							<div class="card-actions justify-between items-center">
								<span class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">
									{post.data.author ?? 'Ray'}
								</span>
								<a href={`/blog/${post.id}`} class="btn btn-primary btn-sm">Read post</a>
							</div>
						</div>
					</article>
				))}
			</section>
		</main>

		<script is:inline>
			if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				document.documentElement.classList.add('motion-safe');

				const revealItems = Array.from(document.querySelectorAll('.motion-reveal'));
				const revealObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add('is-visible');
							revealObserver.unobserve(entry.target);
						});
					},
					{ threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
				);

				revealItems.forEach((item) => revealObserver.observe(item));
			}
		</script>
	</body>
</html>
