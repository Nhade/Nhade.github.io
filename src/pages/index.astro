---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Posts' },
	{ href: '#about', label: 'About' },
];
---

<html lang="en" data-theme="editorial">
	<head>
		<meta charset="utf-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dev Blog</title>
	</head>
	<body class="min-h-screen bg-base-100 text-base-content">
		<div class="min-h-screen">
			<header class="sticky top-0 z-10 bg-base-100/90 backdrop-blur-sm shadow-sm">
				<div class="navbar mx-auto max-w-6xl px-4 sm:px-6">
					<div class="navbar-start">
						<a href="/" class="btn btn-ghost text-lg font-semibold tracking-tight">Dev Blog</a>
					</div>
					<div class="navbar-center hidden lg:flex">
						<ul class="menu menu-horizontal gap-2 px-1">
							{navLinks.map((link) => (
								<li><a href={link.href}>{link.label}</a></li>
							))}
						</ul>
					</div>
					<div class="navbar-end">
						<div class="dropdown dropdown-end lg:hidden">
							<button class="btn btn-ghost" aria-label="Open navigation menu">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
								</svg>
							</button>
							<ul class="menu dropdown-content z-10 mt-3 w-52 rounded-box border border-base-300 bg-base-200 p-2 shadow-lg">
								{navLinks.map((link) => (
									<li><a href={link.href}>{link.label}</a></li>
								))}
							</ul>
						</div>
						<a href="/blog" class="btn btn-primary hidden sm:inline-flex">Read posts</a>
					</div>
				</div>
			</header>

			<main class="mx-auto flex max-w-6xl flex-col gap-16 px-4 py-12 sm:px-6">
				<!-- Hero -->
				<section id="home" class="rounded-box bg-base-200 p-6 sm:p-10">
					<div class="flex w-full flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
						<div class="max-w-2xl space-y-5">
							<div class="badge badge-outline text-xs tracking-widest uppercase">
								Shipping notes, experiments, and lessons learned
							</div>
							<h1 class="font-display text-4xl font-semibold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
								A dev blog built with<br class="hidden sm:block" /> Astro and daisyUI.
							</h1>
							<p class="max-w-xl text-base-content/65 leading-relaxed">
								Start with a clean landing page, a working navigation bar, and room to grow into a proper posts archive.
							</p>
							<div class="flex flex-wrap gap-3 pt-1">
								<a href="/blog/first-post" class="btn btn-primary">Latest post</a>
								<a href="#about" class="btn btn-outline">About this blog</a>
							</div>
						</div>
						<div class="w-full max-w-sm rounded-box border border-base-300 bg-base-300 p-6">
							<p class="text-xs font-medium uppercase tracking-widest text-base-content/50">Current focus</p>
							<h2 class="mt-3 text-lg font-semibold leading-snug">Documenting the build process</h2>
							<p class="mt-2 text-sm text-base-content/65 leading-relaxed">
								This layout gives the blog a usable header, clearer sections, and a better default visual baseline.
							</p>
						</div>
					</div>
				</section>

				<!-- Recent posts -->
				<section id="posts" class="space-y-6">
					<div class="flex items-end justify-between gap-4">
						<div>
							<p class="text-xs font-medium uppercase tracking-widest text-base-content/50">Posts</p>
							<h2 class="mt-1 font-display text-3xl font-semibold">Recent writing</h2>
						</div>
						<a href="/blog" class="link link-hover text-sm hidden sm:inline">Browse all posts →</a>
					</div>

					<div class="grid gap-4">
						{allPosts.map((post) => (
							<article class="rounded-box border border-base-300 bg-base-200 p-6 transition-colors hover:border-primary/30">
								<div class="flex flex-wrap items-center gap-3">
									<time
										datetime={post.data.pubDate.toISOString()}
										class="text-sm text-base-content/50"
									>
										{post.data.pubDate.toISOString().slice(0, 10)}
									</time>
								</div>
								<h3 class="mt-2 text-xl font-semibold leading-snug">{post.data.title}</h3>
								<p class="mt-2 text-sm text-base-content/65 leading-relaxed">{post.data.description}</p>
								<div class="mt-4">
									<a href={`/blog/${post.id}`} class="btn btn-sm btn-outline">Read post</a>
								</div>
							</article>
						))}
					</div>
				</section>

				<!-- About -->
				<section id="about" class="rounded-box border border-base-300 bg-base-200 p-8">
					<p class="text-xs font-medium uppercase tracking-widest text-base-content/50">About</p>
					<h2 class="mt-2 font-display text-3xl font-semibold">What belongs here</h2>
					<p class="mt-4 max-w-2xl text-base-content/65 leading-relaxed">
						Use this section for the blog's purpose, author intro, and links to projects or external profiles. It is intentionally minimal so you can evolve it without undoing a large template.
					</p>
				</section>
			</main>
		</div>
	</body>
</html>
