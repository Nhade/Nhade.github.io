---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Posts' },
	{ href: '#about', label: 'About' },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dev Blog</title>
	</head>
	<body class="min-h-screen bg-base-200 text-base-content">
		<div class="min-h-screen">
			<header class="border-b border-base-300 bg-base-100/90 backdrop-blur">
				<div class="navbar mx-auto max-w-6xl px-4 sm:px-6">
					<div class="navbar-start">
						<a href="/" class="btn btn-ghost text-lg font-semibold">Dev Blog</a>
					</div>
					<div class="navbar-center hidden lg:flex">
						<ul class="menu menu-horizontal gap-2 px-1">
							{navLinks.map((link) => (
								<li><a href={link.href}>{link.label}</a></li>
							))}
						</ul>
					</div>
					<div class="navbar-end">
						<div class="dropdown dropdown-end lg:hidden">
							<button class="btn btn-ghost" aria-label="Open navigation menu">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
								</svg>
							</button>
							<ul class="menu dropdown-content z-10 mt-3 w-52 rounded-box border border-base-300 bg-base-100 p-2 shadow">
								{navLinks.map((link) => (
									<li><a href={link.href}>{link.label}</a></li>
								))}
							</ul>
						</div>
						<a href="/blog" class="btn btn-primary hidden sm:inline-flex">Read posts</a>
					</div>
				</div>
			</header>

			<main class="mx-auto flex max-w-6xl flex-col gap-10 px-4 py-10 sm:px-6">
				<section id="home" class="hero rounded-box bg-base-100 shadow-sm">
					<div class="hero-content w-full flex-col items-start gap-6 px-6 py-10 lg:flex-row lg:items-center lg:justify-between">
						<div class="max-w-2xl space-y-4">
							<div class="badge badge-outline">Shipping notes, experiments, and lessons learned</div>
							<h1 class="text-4xl font-black tracking-tight sm:text-5xl">A simple dev blog home built with Astro and daisyUI.</h1>
							<p class="max-w-xl text-base-content/70">
								Start with a clean landing page, a working navigation bar, and room to grow into a proper posts archive.
							</p>
							<div class="flex flex-wrap gap-3">
								<a href="/blog/first-post" class="btn btn-primary">Latest post</a>
								<a href="#about" class="btn btn-outline">About this blog</a>
							</div>
						</div>
						<div class="card w-full max-w-sm border border-base-300 bg-base-200 shadow">
							<div class="card-body">
								<p class="text-sm uppercase tracking-[0.2em] text-base-content/60">Current focus</p>
								<h2 class="card-title">Documenting the build process</h2>
								<p class="text-base-content/70">
									This starter layout gives the blog a usable header, clearer sections, and a better default visual baseline.
								</p>
							</div>
						</div>
					</div>
				</section>

				<section id="posts" class="space-y-4">
					<div class="flex items-end justify-between gap-4">
						<div>
							<p class="text-sm font-medium uppercase tracking-[0.2em] text-base-content/60">Posts</p>
							<h2 class="text-3xl font-bold">Recent writing</h2>
						</div>
						<a href="/blog" class="link link-hover hidden sm:inline">Browse all posts</a>
					</div>
					{allPosts.map((post) => (
					<div class="card border border-base-300 bg-base-100 shadow-sm">
						<div class="card-body">
							<div class="flex flex-wrap items-center gap-3 text-sm text-base-content/60">
								<div class="badge badge-secondary badge-outline">
									{post.data.pubDate.toISOString().slice(0, 10)}
								</div>
							</div>
							<h3 class="card-title text-2xl">{post.data.title}</h3>
							<p class="text-base-content/70">{post.data.description}</p>
							<div class="card-actions justify-end">
								<a href={`/blog/${post.id}`} class="btn btn-sm btn-outline">Read post</a>
							</div>
						</div>
					</div>
				))}
				</section>

				<section id="about" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm">
					<p class="text-sm font-medium uppercase tracking-[0.2em] text-base-content/60">About</p>
					<h2 class="mt-2 text-3xl font-bold">What belongs here</h2>
					<p class="mt-4 max-w-3xl text-base-content/70">
						Use this section for the blog's purpose, author intro, and links to projects or external profiles. It is intentionally minimal so you can evolve it without undoing a large template.
					</p>
				</section>
			</main>
		</div>
	</body>
</html>
