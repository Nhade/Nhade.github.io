---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Posts' },
	{ href: '/#about', label: 'About' },
];
---

<html lang="en" data-theme="editorial">
	<head>
		<meta charset="utf-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{post.data.title} | Dev Blog</title>
	</head>
	<body class="min-h-screen bg-base-100 text-base-content">
		<header class="sticky top-0 z-10 bg-base-100/90 backdrop-blur-sm shadow-sm">
			<div class="navbar mx-auto max-w-6xl px-4 sm:px-6">
				<div class="navbar-start">
					<a href="/" class="btn btn-ghost text-lg font-semibold tracking-tight">Dev Blog</a>
				</div>
				<div class="navbar-center hidden lg:flex">
					<ul class="menu menu-horizontal gap-2 px-1">
						{navLinks.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</div>
				<div class="navbar-end">
					<div class="dropdown dropdown-end lg:hidden">
						<button class="btn btn-ghost" aria-label="Open navigation menu">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
						<ul class="menu dropdown-content z-10 mt-3 w-52 rounded-box border border-base-300 bg-base-200 p-2 shadow-lg">
							{navLinks.map((link) => (
								<li><a href={link.href}>{link.label}</a></li>
							))}
						</ul>
					</div>
					<a href="/blog" class="btn btn-outline btn-sm hidden sm:inline-flex">All posts</a>
				</div>
			</div>
		</header>

		<main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
			<header class="mb-10 space-y-4">
				<time
					datetime={post.data.pubDate.toISOString()}
					class="text-sm text-base-content/50"
				>
					{post.data.pubDate.toISOString().slice(0, 10)}
				</time>
				<h1 class="font-display text-4xl font-semibold leading-tight sm:text-5xl">
					{post.data.title}
				</h1>
				<p class="text-base-content/65 leading-relaxed">{post.data.description}</p>
			</header>

			<article class="prose lg:prose-lg mx-auto rounded-box border border-base-300 bg-base-200 p-8">
				<Content />
			</article>

			<div class="mt-10">
				<a href="/blog" class="btn btn-outline">← All posts</a>
			</div>
		</main>
	</body>
</html>
