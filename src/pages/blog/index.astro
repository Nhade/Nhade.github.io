---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Posts | Dev Blog</title>
	</head>
	<body class="min-h-screen bg-base-200 text-base-content">
		<div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
			<div class="mb-8 flex flex-wrap items-center justify-between gap-4">
				<div>
					<p class="text-sm font-medium uppercase tracking-[0.2em] text-base-content/60">Dev Blog</p>
					<h1 class="text-4xl font-black">Posts</h1>
				</div>
				<a href="/" class="btn btn-outline">Back home</a>
			</div>

			<div class="grid gap-4">
				{posts.map((post) => (
					<article class="card border border-base-300 bg-base-100 shadow-sm">
						<div class="card-body">
							<div class="flex items-center gap-3 text-sm text-base-content/60">
								<div class="badge badge-outline">{post.data.pubDate.toISOString().slice(0, 10)}</div>
							</div>
							<h2 class="card-title text-2xl">{post.data.title}</h2>
							<p class="text-base-content/70">{post.data.description}</p>
							<div class="card-actions justify-end">
								<a href={`/blog/${post.id}`} class="btn btn-primary btn-sm">Read</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</body>
</html>
