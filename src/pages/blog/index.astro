---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Posts' },
	{ href: '/#about', label: 'About' },
];
---

<html lang="en" data-theme="editorial">
	<head>
		<meta charset="utf-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Posts | Dev Blog</title>
	</head>
	<body class="min-h-screen bg-base-100 text-base-content">
		<header class="sticky top-0 z-10 bg-base-100/90 backdrop-blur-sm shadow-sm">
			<div class="navbar mx-auto max-w-6xl px-4 sm:px-6">
				<div class="navbar-start">
					<a href="/" class="btn btn-ghost text-lg font-semibold tracking-tight">Dev Blog</a>
				</div>
				<div class="navbar-center hidden lg:flex">
					<ul class="menu menu-horizontal gap-2 px-1">
						{navLinks.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</div>
				<div class="navbar-end">
					<div class="dropdown dropdown-end lg:hidden">
						<button class="btn btn-ghost" aria-label="Open navigation menu">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
						<ul class="menu dropdown-content z-10 mt-3 w-52 rounded-box border border-base-300 bg-base-200 p-2 shadow-lg">
							{navLinks.map((link) => (
								<li><a href={link.href}>{link.label}</a></li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</header>

		<main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
			<div class="mb-10">
				<p class="text-xs font-medium uppercase tracking-widest text-base-content/50">Dev Blog</p>
				<h1 class="mt-2 font-display text-4xl font-semibold">Posts</h1>
			</div>

			<div class="grid gap-4">
				{posts.map((post) => (
					<article class="rounded-box border border-base-300 bg-base-200 p-6 transition-colors hover:border-primary/30">
						<time
							datetime={post.data.pubDate.toISOString()}
							class="text-sm text-base-content/50"
						>
							{post.data.pubDate.toISOString().slice(0, 10)}
						</time>
						<h2 class="mt-2 text-xl font-semibold leading-snug">{post.data.title}</h2>
						<p class="mt-2 text-sm text-base-content/65 leading-relaxed">{post.data.description}</p>
						<div class="mt-4">
							<a href={`/blog/${post.id}`} class="btn btn-sm btn-primary">Read</a>
						</div>
					</article>
				))}
			</div>
		</main>
	</body>
</html>
